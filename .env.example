# Supabase (Auth & Database)
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Intelligence (Gemini & Embeddings)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEYS=your-google-ai-api-key
# Alternatively, you can provide a comma-separated list of keys for automatic failover:
# GOOGLE_AI_API_KEYS="key1,key2,key3"

# Academic Sources
# SerpAPI: https://serpapi.com/dashboard
SERPAPI_KEY=your-serpapi-key
# Semantic Scholar (optional – leave blank to use unauthenticated rate limits)
# Get from: https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

